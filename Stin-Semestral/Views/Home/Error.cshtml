@{
    ViewData["Title"] = "Chyba " + (ViewBag.StatusCode ?? "");
}

<div class="container mt-5">
    <div class="text-center py-5 shadow-sm bg-white rounded border">
        <h1 class="display-1 fw-bold text-danger">
            @(ViewBag.StatusCode ?? "Chyba")
        </h1>

        <div class="mb-4">
            <i class="bi @(ViewBag.Icon ?? "bi-bug")" style="font-size: 4rem; color: #6c757d;"></i>
        </div>

        <h2 class="h4 mb-3">@ViewBag.ErrorMessage</h2>

        <p class="text-muted mb-4">
            Pokud si myslíte, že jde o chybu v systému, kontaktujte prosím správce (admina).
        </p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
            <i class="bi bi-house-door me-2"></i>Zpět na hlavní stránku
        </a>
    </div>
</div>
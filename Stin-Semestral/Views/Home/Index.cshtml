@model List<Stin_Semestral.Models.Currency>

@{
    ViewData["Title"] = "Kurzovní lístek";
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center bg-white p-4 rounded shadow-sm border">
        <div class="col-md-7">
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-graph-up-arrow text-primary me-2"></i>Moje sledované kurzy
            </h2>
            <p class="text-muted mb-0">
                Základní měna: <span class="badge bg-primary fs-6">1 @ViewBag.BaseCurrency</span> |
                Aktualizováno: <strong>@ViewBag.LastUpdate</strong>
            </p>
        </div>
        <div class="col-md-5 text-md-end mt-3 mt-md-0">
            <a asp-controller="Settings" asp-action="Index" class="btn btn-outline-primary btn-lg shadow-sm">
                <i class="bi bi-gear-fill me-2"></i>Upravit sledování
            </a>

            <form asp-action="UpdateRates" method="post" class="d-inline ms-2">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm" title="Stáhnout nová data z API">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive" style="max-height: 700px;">
            <table class="table table-hover align-middle mb-0">
                <thead class="sticky-top">
                    <tr>
                        <th class="ps-4" style="width: 30%;">Měna</th>
                        <th style="width: 40%;">Aktuální kurz (v @ViewBag.BaseCurrency)</th>
                        <th style="width: 30%;">Datum záznamu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold text-dark fs-5">@item.Name</span>
                                    @if (item.Name == ViewBag.BaseCurrency)
                                    {
                                        <span class="ms-2 badge rounded-pill bg-light text-primary border border-primary small">Základ</span>
                                    }
                                </td>
                                <td>
                                    <span class="font-monospace fs-4 fw-bold text-primary">
                                        @item.Rate.ToString("N4")
                                    </span>
                                    <span class="text-muted ms-1 small">@ViewBag.BaseCurrency</span>
                                </td>
                                <td>
                                    <span class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i> @item.Date.ToString("dd.MM.yyyy")
                                        <i class="bi bi-clock ms-2 me-1"></i> @item.Date.ToString("HH:mm")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-database-exclamation display-1"></i>
                                    <p class="mt-3 fs-5">Nenalezena žádná data pro vybrané měny.</p>
                                    <a asp-controller="Settings" asp-action="Index" class="btn btn-primary">
                                        Přejít do nastavení
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white py-3 text-center">
            <small class="text-muted">
                Kurzy jsou automaticky přepočítávány z výchozího kurzu USD poskytovaného API.
            </small>
        </div>
    </div>
</div>
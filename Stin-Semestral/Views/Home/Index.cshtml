@model List<Stin_Semestral.Models.CurrencyViewModel>

@{
    ViewData["Title"] = "Přehled měn";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 h-100 bg-primary text-white text-center p-3">
                <h6 class="text-uppercase small fw-bold opacity-75">Základní měna</h6>
                <h2 class="fw-bold mb-0">1 @ViewBag.BaseCurrency</h2>
            </div>
        </div>
        @if (ViewBag.Strongest != null)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0 h-100 bg-success text-white text-center p-3">
                    <h6 class="text-uppercase small fw-bold opacity-75">Nejsilnější měna</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.Strongest.Name</h2>
                    <div>@ViewBag.Strongest.CurrentRate.ToString("N4")</div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0 h-100 bg-danger text-white text-center p-3">
                    <h6 class="text-uppercase small fw-bold opacity-75">Nejslabší měna</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.Weakest.Name</h2>
                    <div>@ViewBag.Weakest.CurrentRate.ToString("N4")</div>
                </div>
            </div>
        }
    </div>

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold">Aktuální kurzy a průměry</h5>
            <a asp-controller="Settings" asp-action="Index" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-gear-fill"></i> Nastavení
            </a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small">
                    <tr>
                        <th class="ps-4">MĚNA</th>
                        <th>KURZ (@ViewBag.BaseCurrency)</th>
                        <th>30D PRŮMĚR</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Name</td>
                            <td class="text-primary fw-bold">@item.CurrentRate.ToString("N4")</td>
                            <td>@item.Average30Days.ToString("N4")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <h4 class="fw-bold mb-4">Historický vývoj vybraných měn</h4>
    <div class="row">
        @foreach (var item in Model)
        {
            @if (item.Name != ViewBag.BaseCurrency)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0">@item.Name / @ViewBag.BaseCurrency</h6>
                                <span class="badge bg-light text-dark border">30 dní</span>
                            </div>
                            <div style="height: 200px; position: relative;">
                                <canvas id="chart-@item.Name"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        @foreach (var item in Model)
        {
            if (item.Name != ViewBag.BaseCurrency && !string.IsNullOrEmpty(item.HistoryJson))
            {
                <text>
                        (function() {
                            const ctx = document.getElementById('chart-@item.Name').getContext('2d');
                            const data = @Html.Raw(item.HistoryJson);

                            new Chart(ctx, {
                                type: 'line',
                                data: {
                                    labels: data.map((_, i) => i + 1),
                                    datasets: [{
                                        label: 'Kurz',
                                        data: data,
                                        borderColor: '#0d6efd',
                                        backgroundColor: 'rgba(13, 110, 253, 0.05)',
                                        fill: true,
                                        tension: 0.3,
                                        pointRadius: 0,
                                        borderWidth: 2
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { display: false } },
                                    scales: {
                                        x: { display: false },
                                        y: {
                                            beginAtZero: false,
                                            grace: '5%',
                                            ticks: { font: { size: 10 } }
                                        }
                                    }
                                }
                            });
                        })();
                </text>
            }
        }
        });
    </script>
}
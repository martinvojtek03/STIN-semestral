@model List<Stin_Semestral.Models.Currency>

@{
    ViewData["Title"] = "Sledované měny";
}

<div class="row mb-4 align-items-center bg-white p-4 rounded shadow-sm border">
    <div class="col-md-12">
        <h2 class="fw-bold text-dark mb-1">Moje sledované kurzy</h2>
        <p class="text-muted mb-0">
            Základní měna systému: <strong>USD</strong> |
            Sledovaných měn: <strong>@Model.Count</strong> |
            <span class="badge bg-light text-dark border">
                <i class="bi bi-clock me-1"></i> @(ViewBag.LastUpdate)
            </span>
        </p>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="sticky-top">
                <tr>
                    <th class="ps-4">Měna</th>
                    <th>Kurz (1 USD = X)</th>
                    <th>Poslední změna</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-primary">@item.Name</span>
                            </td>
                            <td class="font-monospace fs-5">@item.Rate.ToString("N4")</td>
                            <td class="text-muted small">@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            <i class="bi bi-filter-circle display-4"></i>
                            <p class="mt-2">Žádné z vašich sledovaných měn nebyly v databázi nalezeny.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-end">
    <small class="text-muted italic">Data jsou filtrována podle vašeho nastavení.</small>
</div>
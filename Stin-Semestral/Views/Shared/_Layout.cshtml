<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Směnárna STIN</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-currency-exchange text-primary me-2"></i>STIN Směnárna
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item me-3">
                            <span class="nav-link text-white-50 small">@DateTime.Now.ToString("dd.MM.yyyy")</span>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm nav-link px-3 text-white" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Odhlásit (admin)
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link small" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-person-lock"></i> Login
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1 pb-3">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted bg-white py-4 mt-auto">
        <div class="container text-center">
            <div class="mb-2">
                &copy; @DateTime.Now.Year - <strong>Semestrální práce STIN</strong>
            </div>
            <div class="d-flex justify-content-center gap-4">
                <a asp-controller="Log" asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-cpu"></i> Status systému
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Settings" asp-action="Index" class="text-decoration-none text-success">
                        <i class="bi bi-gear-fill"></i> Nastavení měn
                    </a>
                }

                <span class="text-secondary small">Jazyk: CZ</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model List<Stin_Semestral.Models.LogViewModel>

@{
    ViewData["Title"] = "Systémové Logy";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-journal-text me-2"></i>Systémové Logy</h2>
        <span class="badge bg-secondary">Posledních 100 záznamů</span>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 200px;">Čas</th>
                        <th style="width: 100px;">Úroveň</th>
                        <th>Zpráva</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        var rowClass = log.Level == "ERROR" ? "table-danger" : "";
                        var badgeClass = log.Level == "ERROR" ? "bg-danger" : "bg-info";

                        <tr class="@rowClass">
                            <td class="text-muted small">
                                @log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")
                            </td>
                            <td>
                                <span class="badge @badgeClass">@log.Level</span>
                            </td>
                            <td class="font-monospace small">@log.Message</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-end">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Zpět na kurzy
        </a>
    </div>
</div>  
## --- DOTNET / VISUAL STUDIO ---
# Ignoruje binární data a dočasné soubory z buildu
[Bb]in/
[Oo]bj/
[Tt]est[Rr]esults/

# Uživatelské nastavení Visual Studia a dočasné soubory
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo

# NuGet balíčky (stahují se automaticky při buildu, není třeba je verzovat)
packages/
*.nupkg
# Pokud používáš .NET Core/5+, balíčky se ukládají v profilu uživatele, 
# ale složka 'project.lock.json' nebo 'project.assets.json' se může objevit
project.assets.json

## --- DATABÁZE (SQLite) ---
# Ignoruje lokální soubor databáze, aby se nepřebíjela data mezi vývojáři
*.db
*.db-journal
*.db-shm
*.db-wal

## --- FRONTEND (Node.js / React) ---
# Pokud tvůj projekt obsahuje webový frontend, tohle zabrání nahrání tisíců knihoven
node_modules/
npm-debug.log*
dist/
build/
.env.local
.env.development.local
.env.test.local
.env.production.local

## --- OPERAČNÍ SYSTÉMY ---
# Windows balast
Thumbs.db
ehthumbs.db
desktop.ini

# macOS balast
.DS_Store

## --- KONFIGURACE / TAJEMSTVÍ ---
# Ignoruje soubory, které by mohly obsahovat hesla nebo API klíče
appsettings.Development.json
secrets.